#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = C:\msys64\clang64\bin\cmake.exe --regenerate-during-build -SC:\Users\jghig\projects\cxx\gican -BC:\Users\jghig\projects\cxx\gican\out\debug
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = C:\msys64\clang64\bin\ninja.exe $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = C:\msys64\clang64\bin\ninja.exe -t targets
  description = All primary targets available:

